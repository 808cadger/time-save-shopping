{
  "expo": {
    "name": "time~save~shopping",
    "slug": "timesave-shopping",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "timesave",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#22c55e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.timesaveshopping.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "time~save~shopping uses your location to detect when you enter a store and guide you to items."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#22c55e"
      },
      "package": "com.timesaveshopping.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "versionCode": 1
    },
    "plugins": [
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "9878068f-64d2-46f0-84c7-1c0b3eefcd6a"
      }
    },
    "runtimeVersion": "1.0.0"
  }
}
